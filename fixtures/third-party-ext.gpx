<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="DMD HUB GPX Planner"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:rumo="https://www.rumoadventures.com/xmlschemas/GpxExtensions/v1">
  <rte>
    <name>Third-party ext route</name>
    <extensions>
      <rumo:RouteExtension>
        <rumo:RoutingProfile>motorcycle</rumo:RoutingProfile>
      </rumo:RouteExtension>
    </extensions>
    <rtept lat="52.0000000" lon="4.0000000">
      <name>Start</name>
    </rtept>
    <rtept lat="52.0100000" lon="4.0100000">
      <name>End</name>
    </rtept>
  </rte>
</gpx>
