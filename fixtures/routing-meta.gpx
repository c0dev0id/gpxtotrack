<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Garmin Desktop App"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:gpxx="http://www.garmin.com/xmlschemas/GpxExtensions/v3"
     xmlns:trp="http://www.garmin.com/xmlschemas/TripExtensions/v1">
  <rte>
    <name>Routing meta route</name>
    <extensions>
      <trp:Trip>
        <trp:TransportationMode>Motorcycling</trp:TransportationMode>
      </trp:Trip>
    </extensions>
    <rtept lat="52.0000000" lon="4.0000000">
      <name>Start</name>
      <extensions>
        <trp:ViaPoint>
          <trp:DepartureTime>2024-06-01T08:00:00Z</trp:DepartureTime>
        </trp:ViaPoint>
      </extensions>
    </rtept>
    <rtept lat="52.0020000" lon="4.0020000">
      <extensions>
        <gpxx:RoutePointExtension>
          <gpxx:rpt lat="52.0015000" lon="4.0015000"/>
        </gpxx:RoutePointExtension>
        <trp:ShapingPoint/>
      </extensions>
    </rtept>
    <rtept lat="52.0100000" lon="4.0100000">
      <name>End</name>
      <extensions>
        <trp:ViaPoint/>
      </extensions>
    </rtept>
  </rte>
</gpx>
