<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="BaseCamp"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:gpxx="http://www.garmin.com/xmlschemas/GpxExtensions/v3">
  <wpt lat="52.0500000" lon="4.0500000">
    <time>2024-06-01T12:00:00Z</time>
    <name>Coffee stop</name>
    <sym>Restaurant</sym>
    <extensions>
      <gpxx:WaypointExtension>
        <gpxx:Proximity>10</gpxx:Proximity>
        <gpxx:DisplayMode>SymbolAndName</gpxx:DisplayMode>
        <gpxx:Address>
          <gpxx:StreetAddress>Main St 1</gpxx:StreetAddress>
        </gpxx:Address>
      </gpxx:WaypointExtension>
    </extensions>
  </wpt>
  <rte>
    <name>With waypoints</name>
    <rtept lat="52.0000000" lon="4.0000000">
      <name>Start</name>
      <sym>Flag, Green</sym>
    </rtept>
    <rtept lat="52.0030000" lon="4.0030000">
      <extensions>
        <gpxx:RoutePointExtension>
          <gpxx:rpt lat="52.0040000" lon="4.0045000"/>
        </gpxx:RoutePointExtension>
      </extensions>
    </rtept>
    <rtept lat="52.0100000" lon="4.0100000">
      <name>End</name>
      <sym>Flag, Red</sym>
    </rtept>
  </rte>
</gpx>
